html
  head
    meta(name="viewport", content="width=device-width, initial-scale=1.0")
    meta(name="x-apple-disable-message-reformatting")
    meta(http-equiv="Content-Type", content="text/html; charset=UTF-8")
    meta(name="color-scheme", content="light dark")
    title #{company} Password Reset Request
    link(rel="stylesheet", href="/css/styles.css", data-inline)
  body
    span(class="preheader") Use this code to reset your password. The code is only valid for the next hour.
    table(class="email-wrapper", width="100%", cellpadding="0", cellspacing="0", role="presentation")
      tr
        td(align="center")
          table(class="email-content", width="100%", cellpadding="0", cellspacing="0", role="presentation")
            tr
              td(class="email-masthead")
                a(href="#{website}", class="f-fallback email-masthead_name") #{company}
            tr
              td(class="email-body", width="570", cellpadding="0", cellspacing="0")
                table(class="email-body_inner", align="center", width="570", cellpadding="0", cellspacing="0", role="presentation")
                  tr
                    td(class="content-cell")
                      div(class="f-fallback")
                        h1 Hi #{name}
                        p
                          | You recently requested to reset your password for your #{company} account. Use the code below with the
                          pre
                            code /account password [code] [password] [password]
                          | command in discord to reset it. This code is only valid for the next hour.
                        table(class="body-action", align="center", width="100%", cellpadding="0", cellspacing="0", role="presentation")
                          tr
                            td(align="center")
                              table(width="100%", border="0", cellspacing="0", cellpadding="0", role="presentation")
                                tr
                                  td(align="center", class="code") #{code}
                        p If you did not request a password reset, please ignore this email or contact support if you have questions.
                        p Thanks,
                          br
                          | The #{company} Team
            tr
              td
                table(class="email-footer", align="center", width="570", cellpadding="0", cellspacing="0", role="presentation")
                  tr
                    td(class="content-cell", align="center")
                      p(class="f-fallback sub align-center") &copy; 2021 #{company}. All rights reserved.